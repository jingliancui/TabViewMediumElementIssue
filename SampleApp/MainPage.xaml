<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:SampleApp"
             xmlns:tabView="clr-namespace:Syncfusion.Maui.Toolkit.TabView;assembly=Syncfusion.Maui.Toolkit"
             x:Class="SampleApp.MainPage">

    <tabView:SfTabView
        x:Name="MainTabView"
        IsCenterButtonEnabled="True"
        EnableVirtualization="True"
        FontAutoScalingEnabled="True"
        TabBarPlacement="Bottom">
        
        <tabView:SfTabView.CenterButtonSettings>
            <tabView:CenterButtonSettings
                Width="45"
                Height="45"
                CornerRadius="50"
                ImageSize="25"
                DisplayMode="Image"
                ImageSource="dotnet_bot.png"></tabView:CenterButtonSettings>
        </tabView:SfTabView.CenterButtonSettings>
        <tabView:SfTabView.Items>
            <tabView:SfTabItem Header="Customize1">
                <views:CustomizeView></views:CustomizeView>
            </tabView:SfTabItem>
            <tabView:SfTabItem Header="Customize2">
                <views:CustomizeView></views:CustomizeView>
            </tabView:SfTabItem>
        </tabView:SfTabView.Items>
    </tabView:SfTabView>
</ContentPage>
