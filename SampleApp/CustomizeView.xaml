<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:SampleApp"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="views:CustomizeViewViewModel"
             x:Class="SampleApp.CustomizeView">
    <VerticalStackLayout>
        <Label Text="Title"></Label>
        <CollectionView
            ItemsSource="{Binding ListItems}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="views:CustomizeListViewModel">
                    <VerticalStackLayout>
                        <Label Text="{Binding TheName,Mode=TwoWay}"></Label>
                        
                        <toolkit:MediaElement
                            ShouldShowPlaybackControls="True"
                            x:Name="RecordedVideoPlayer"
                            WidthRequest="250"
                            HeightRequest="200"
                            HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentView>
